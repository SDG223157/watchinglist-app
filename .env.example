# Neon Postgres connection string
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Auth.js (NextAuth v5)
AUTH_SECRET=  # Generate with: openssl rand -base64 32
AUTH_URL=https://watchinglist.app

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Restrict access to specific emails (comma-separated, leave empty to allow all)
ALLOWED_EMAILS=

# OpenRouter API key for LLM analysis reports (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Financial Modeling Prep API key (https://financialmodelingprep.com/developer)
FMP_API_KEY=

# Polymarket overlay global kill-switch for Recipe Portfolio prior-mu nudge.
# Reads polymarket_ticker_tilts.z_live (already per-mapping-weighted by the
# botboard-private producer via polymarket_mapping_lambdas). This dial is now
# just a global on/off multiplier, clamped to [0, 1].
#   0    = shadow       (read z_live, surface in UI, do NOT nudge weights)
#   0.5  = half-strength (first live week after governance table lights up)
#   1    = trust governance fully (steady state)
# Default 0 so any deploy is safe even if the producer promotes new mappings.
POLYMARKET_LAMBDA=0
