# Neon Postgres connection string
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Auth.js (NextAuth v5)
AUTH_SECRET=  # Generate with: openssl rand -base64 32
AUTH_URL=https://watchinglist.app

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Restrict access to specific emails (comma-separated, leave empty to allow all)
ALLOWED_EMAILS=

# OpenRouter API key for LLM analysis reports (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Financial Modeling Prep API key (https://financialmodelingprep.com/developer)
FMP_API_KEY=

# Polymarket overlay lambda for Recipe Portfolio prior-mu nudge.
# Reads polymarket_ticker_tilts (written by botboard-private daily cron).
# Hard cap 0.25. Default 0 = shadow mode (tilts surfaced in UI, not applied).
# Promotion path: 0 -> 0.05 (first live after BH-FDR backtest pass) -> 0.25.
POLYMARKET_LAMBDA=0
